{
  "name": "deckide",
  "version": "3.5.6",
  "description": "Deck IDE - Browser-based IDE with terminal, file explorer, and git integration",
  "type": "module",
  "bin": {
    "deckide": "bin/deckide.js"
  },
  "files": [
    "bin/",
    "dist/",
    "web/dist/"
  ],
  "scripts": {
    "dev:web": "cd web && npx vite",
    "dev:server": "npx tsx src/index.ts",
    "build:web": "cd web && npx vite build",
    "build:server": "tsc",
    "build": "npm run build:web && npm run build:server",
    "serve": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@hono/node-server": "^1.12.2",
    "hono": "^4.5.10",
    "node-pty": "^1.0.0",
    "simple-git": "^3.27.0",
    "ws": "^8.17.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.10.9",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.2.1",
    "clsx": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.2.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-unicode11": "^0.6.0",
    "xterm-addon-web-links": "^0.9.0",
    "xterm-addon-webgl": "^0.16.0"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tako0614/ide.git"
  },
  "keywords": [
    "ide",
    "editor",
    "terminal",
    "web-ide",
    "developer-tools"
  ],
  "author": "tako0614",
  "license": "MIT"
}
